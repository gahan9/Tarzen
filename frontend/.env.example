# SPDX-License-Identifier: MIT
# Copy to `.env.local` and fill in real values. NEVER commit `.env.local`.
# All client-exposed vars must be prefixed with VITE_ (Vite only inlines those).
# Firebase web config values are NOT secrets (they ship in the client bundle),
# but they still belong in env so the build is environment-portable.

# Base URL of the FastAPI backend (Cloud Run). No trailing slash.
VITE_API_BASE_URL=http://localhost:8080

# When "true", the app uses a local mock of /api/footprint instead of the
# network (handy for UI dev before the backend is reachable).
VITE_USE_MOCK_API=false

# Firebase Web SDK configuration (from the Firebase console > Project settings).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
