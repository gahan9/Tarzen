  "components": {
    "schemas": {
      "Body_create_ticket_savings_api_savings_ticket_post": {
        "properties": {
          "image": {
            "type": "string",
            "contentMediaType": "application/octet-stream",
            "title": "Image"
          }
        },
        "type": "object",
        "required": [
          "image"
        ],
        "title": "Body_create_ticket_savings_api_savings_ticket_post"
      },
      "BreakdownItem": {
        "properties": {
          "label": {
            "type": "string",
            "title": "Label"
          },
          "kg_co2e": {
            "type": "number",
            "title": "Kg Co2E"
          }
        },
        "type": "object",
        "required": [
          "label",
          "kg_co2e"
        ],
        "title": "BreakdownItem",
        "description": "A labelled contribution to the footprint total."
      },
      "CarpoolImportRow": {
        "properties": {
          "date": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Date",
            "examples": [
              "2026-06-01"
            ]
          },
          "distance_km": {
            "type": "number",
            "maximum": 100000.0,
            "minimum": 0.0,
            "title": "Distance Km",
            "examples": [
              18.5
            ]
          },
          "passengers": {
            "type": "integer",
            "maximum": 1000.0,
            "minimum": 1.0,
            "title": "Passengers",
            "default": 1,
            "examples": [
              2
            ]
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "distance_km"
        ],
        "title": "CarpoolImportRow",
        "description": "One row of a CSV/trip-history carpool import (carpool is implied)."
      },
      "ErrorDetail": {
        "properties": {
          "code": {
            "type": "string",
            "title": "Code"
          },
          "message": {
            "type": "string",
            "title": "Message"
          },
          "request_id": {
            "type": "string",
            "title": "Request Id"
          }
        },
        "type": "object",
        "required": [
          "code",
          "message",
          "request_id"
        ],
        "title": "ErrorDetail",
        "description": "Machine-readable error detail carried inside the envelope."
      },
      "ErrorEnvelope": {
        "properties": {
          "error": {
            "$ref": "#/components/schemas/ErrorDetail"
          }
        },
        "type": "object",
        "required": [
          "error"
        ],
        "title": "ErrorEnvelope",
        "description": "Top-level error envelope returned for every failed request."
      },
      "FootprintRequest": {
        "properties": {
          "domain": {
            "type": "string",
            "minLength": 1,
            "title": "Domain",
            "examples": [
              "transport"
            ]
          },
          "mode": {
            "anyOf": [
              {
                "type": "string",
                "enum": [
                  "car",
                  "bus",
                  "rail",
                  "flight"
                ]
              },
              {
                "type": "string",
                "enum": [
                  "electricity",
                  "natural_gas"
                ]
              },
              {
                "type": "string",
                "enum": [
                  "beef_meal",
                  "pork_meal",
                  "chicken_meal",
                  "fish_meal",
                  "vegetarian_meal",
                  "vegan_meal"
                ]
              },
              {
                "type": "string",
                "enum": [
                  "clothing",
                  "electronics",
                  "furniture",
                  "general_goods"
                ]
              },
              {
                "type": "string",
                "enum": [
                  "landfill",
                  "recycling",
                  "composting"
                ]
              }
            ],
            "title": "Mode",
            "examples": [
              "car"
            ]
          },
          "distance_km": {
            "anyOf": [
              {
                "type": "number",
                "maximum": 100000.0,
                "minimum": 0.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Distance Km",
            "examples": [
              42.0
            ]
          },
          "passengers": {
            "type": "integer",
            "maximum": 1000.0,
            "minimum": 1.0,
            "title": "Passengers",
            "default": 1,
            "examples": [
              1
            ]
          },
          "kwh": {
            "anyOf": [
              {
                "type": "number",
                "maximum": 1000000.0,
                "minimum": 0.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Kwh",
            "examples": [
              120.0
            ]
          },
          "servings": {
            "anyOf": [
              {
                "type": "integer",
                "maximum": 100.0,
                "minimum": 0.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Servings",
            "examples": [
              2
            ]
          },
          "spend": {
            "anyOf": [
              {
                "type": "number",
                "maximum": 10000000.0,
                "minimum": 0.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Spend",
            "examples": [
              50.0
            ]
          },
          "waste_kg": {
            "anyOf": [
              {
                "type": "number",
                "maximum": 1000000.0,
                "minimum": 0.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Waste Kg",
            "examples": [
              3.0
            ]
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "domain",
          "mode"
        ],
        "title": "FootprintRequest",
        "description": "Request body for a footprint calculation.\n\nA single ``mode`` plus exactly one activity quantity describes the activity.\nThe transport contract (``distance_km`` + ``passengers``) is preserved; new\ndomains add their own optional quantity field (``kwh``, ``servings``,\n``spend``, ``waste_kg``). The tracker for the requested domain validates\nthat the quantity it needs is present."
      },
      "FootprintResponse": {
        "properties": {
          "kg_co2e": {
            "type": "number",
            "title": "Kg Co2E"
          },
          "breakdown": {
            "items": {
              "$ref": "#/components/schemas/BreakdownItem"
            },
            "type": "array",
            "title": "Breakdown"
          },
          "insight": {
            "$ref": "#/components/schemas/Insight"
          },
          "request_id": {
            "type": "string",
            "title": "Request Id"
          }
        },
        "type": "object",
        "required": [
          "kg_co2e",
          "breakdown",
          "insight",
          "request_id"
        ],
        "title": "FootprintResponse",
        "description": "Successful response for a footprint calculation."
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "Insight": {
        "properties": {
          "message": {
            "type": "string",
            "title": "Message"
          },
          "benchmark": {
            "type": "string",
            "title": "Benchmark"
          },
          "actions": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Actions"
          },
          "needs_context": {
            "type": "boolean",
            "title": "Needs Context"
          },
          "llm_used": {
            "type": "boolean",
            "title": "Llm Used"
          }
        },
        "type": "object",
        "required": [
          "message",
          "benchmark",
          "actions",
          "needs_context",
          "llm_used"
        ],
        "title": "Insight",
        "description": "Human-friendly framing of a footprint result."
      },
      "LeaderboardEntry": {
        "properties": {
          "anon_handle": {
            "type": "string",
            "title": "Anon Handle"
          },
          "emoji": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Emoji"
          },
          "score": {
            "type": "number",
            "title": "Score"
          },
          "rank": {
            "type": "integer",
            "title": "Rank"
          },
          "is_me": {
            "type": "boolean",
            "title": "Is Me",
            "default": false
          }
        },
        "type": "object",
        "required": [
          "anon_handle",
          "score",
          "rank"
        ],
        "title": "LeaderboardEntry",
        "description": "A single ranked, anonymised competitor."
      },
      "LeaderboardResponse": {
        "properties": {
          "scope": {
            "type": "string",
            "enum": [
              "region",
              "global"
            ],
            "title": "Scope"
          },
          "region": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Region"
          },
          "entries": {
            "items": {
              "$ref": "#/components/schemas/LeaderboardEntry"
            },
            "type": "array",
            "title": "Entries"
          },
          "my_rank": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "My Rank"
          },
          "percentile": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Percentile"
          },
          "tips": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Tips"
          }
        },
        "type": "object",
        "required": [
          "scope",
          "entries",
          "tips"
        ],
        "title": "LeaderboardResponse",
        "description": "Anonymous leaderboard view with the caller's standing and tips."
      },
      "ProfileResponse": {
        "properties": {
          "anon_handle": {
            "type": "string",
            "title": "Anon Handle"
          },
          "emoji": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Emoji"
          },
          "region": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Region"
          },
          "points": {
            "type": "integer",
            "title": "Points"
          },
          "streak_days": {
            "type": "integer",
            "title": "Streak Days"
          },
          "badges": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Badges"
          },
          "total_kg_co2e_saved": {
            "type": "number",
            "title": "Total Kg Co2E Saved"
          },
          "my_rank": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "My Rank"
          },
          "percentile": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Percentile"
          }
        },
        "type": "object",
        "required": [
          "anon_handle",
          "points",
          "streak_days",
          "badges",
          "total_kg_co2e_saved"
        ],
        "title": "ProfileResponse",
        "description": "The caller's anonymous, public-safe profile and gamification state."
      },
      "SavingsImportRequest": {
        "properties": {
          "rows": {
            "items": {
              "$ref": "#/components/schemas/CarpoolImportRow"
            },
            "type": "array",
            "maxItems": 500,
            "minItems": 1,
            "title": "Rows"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "rows"
        ],
        "title": "SavingsImportRequest",
        "description": "Request body for a batch carpool import."
      },
      "SavingsImportResponse": {
        "properties": {
          "total_kg_co2e_saved": {
            "type": "number",
            "title": "Total Kg Co2E Saved"
          },
          "rows_imported": {
            "type": "integer",
            "title": "Rows Imported"
          },
          "points_awarded": {
            "type": "integer",
            "title": "Points Awarded"
