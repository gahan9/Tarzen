# SPDX-License-Identifier: MIT
# Copy to `.env` (gitignored) and fill in real values. NEVER commit `.env`.
# Expo only inlines variables prefixed with EXPO_PUBLIC_ into the client bundle.
# Firebase web/app config values are NOT secrets (they ship in the client), but
# they still belong in env so the build is environment-portable. No private keys
# or service-account credentials ever go here.

# Base URL of the FastAPI backend (Cloud Run). No trailing slash.
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080

# When "true" (the default for offline/local dev), the app uses a local mock of
# /api/footprint instead of the network so it runs without the backend.
EXPO_PUBLIC_USE_MOCK_API=true

# Firebase configuration (Firebase console > Project settings). When absent, the
# app runs in an anonymous, sign-in-disabled mode rather than crashing.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# FCM push nudges. Registration/handlers no-op unless this is "true" AND an EAS
# project id is present (required to mint an Expo push token).
EXPO_PUBLIC_ENABLE_PUSH=false
EXPO_PUBLIC_EAS_PROJECT_ID=
