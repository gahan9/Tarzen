# Copy to .env and fill in real values. NEVER commit .env to git.
# .env is gitignored and blocked by .ai/hooks/guard-env-files.py.

# Application
APP_LOG_LEVEL=INFO
APP_PORT=8080

# CORS — exact origins only, comma-separated. Never use "*".
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Google Cloud / Vertex AI (Carbon Footprint Platform backend)
GCP_PROJECT_ID=your-gcp-project-id
VERTEX_REGION=us-central1
GEMINI_MODEL_ID=gemini-1.5-flash

# Optional: path-free service-account JSON for non-ADC environments.
# Prefer Application Default Credentials / Secret Manager in production.
# SERVICE_ACCOUNT_KEY=

# LLM gateway (only if your project calls a non-Vertex LLM)
LLM_BASE_URL=https://api.example.com
LLM_API_KEY=your-token-here
LLM_APP_NAME=your-app-name
LLM_MODEL=your-model-id

# Savings / verified tickets
# Maps Distance Matrix key for ticket distance lookups (Secret Manager in prod).
# Absent => the distance provider is disabled and ticket verification degrades.
# MAPS_API_KEY=
MAX_IMAGE_BYTES=5000000

# Leaderboard / region
# Coarse geo header set by the load balancer; used to derive the region cohort.
GEO_COUNTRY_HEADER=x-client-geo-country
LEADERBOARD_TOP_N=50

# Memorystore (Redis) leaderboard ZSET. When REDIS_HOST is set, the backend
# uses the Redis-backed store instead of the per-instance in-memory store.
# REDIS_HOST=
REDIS_PORT=6379
# REDIS_PASSWORD=
REDIS_USE_TLS=false
